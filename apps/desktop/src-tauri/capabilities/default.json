{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables all permissions for ACode",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "sql:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "notification:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://api.openai.com/**" },
        { "url": "https://api.anthropic.com/**" },
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "git", "cmd": "git", "args": true },
        { "name": "zsh", "cmd": "zsh", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "cmd", "cmd": "cmd", "args": true },
        { "name": "tasklist", "cmd": "tasklist", "args": true },
        { "name": "ps", "cmd": "ps", "args": true },
        { "name": "df", "cmd": "df", "args": true },
        { "name": "kill", "cmd": "kill", "args": true },
        { "name": "taskkill", "cmd": "taskkill", "args": true },
        { "name": "npx", "cmd": "npx", "args": true },
        { "name": "node", "cmd": "node", "args": true },
        { "name": "python", "cmd": "python", "args": true },
        { "name": "python3", "cmd": "python3", "args": true }
      ]
    },
    "shell:allow-open",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$HOME/**" }, { "path": "$DESKTOP/**" }]
    }
  ]
}
