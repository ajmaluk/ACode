{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables all permissions for Dalam",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-watch",
    "fs:scope-home-recursive",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "notification:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://**" },
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "git", "cmd": "git", "args": true },
        { "name": "tasklist", "cmd": "tasklist", "args": true },
        { "name": "ps", "cmd": "ps", "args": true },
        { "name": "df", "cmd": "df", "args": true },
        { "name": "kill", "cmd": "kill", "args": true },
        { "name": "taskkill", "cmd": "taskkill", "args": true },
        { "name": "npx", "cmd": "npx", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "zsh", "cmd": "zsh", "args": true },
        { "name": "fish", "cmd": "fish", "args": true },
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "pwsh", "cmd": "pwsh", "args": true },
        { "name": "cmd", "cmd": "cmd", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "zsh", "cmd": "zsh", "args": true },
        { "name": "fish", "cmd": "fish", "args": true },
        { "name": "sh", "cmd": "sh", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "pwsh", "cmd": "pwsh", "args": true },
        { "name": "cmd", "cmd": "cmd", "args": true }
      ]
    },
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "shell:allow-open"
  ]
}
