{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dalam",
  "version": "0.1.0",
  "identifier": "com.dalam.desktop",
  "build": {
    "frontendDist": "../out/renderer",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Dalam",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "label": "main",
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; script-src 'self' https://cdn.jsdelivr.net blob: 'unsafe-eval'; img-src 'self' data: blob: http: https:; font-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self' ipc: http: https: ws: wss:; worker-src 'self' blob:; manifest-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["ts", "tsx", "js", "jsx", "py", "rs", "go", "md", "json", "yaml", "yml", "toml"],
        "name": "Source Code",
        "description": "Source code files"
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["dalam"]
      }
    }
  }
}